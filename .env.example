# DeepSeek powers song analysis. Get a key (5M free signup tokens) at
# https://platform.deepseek.com
DEEPSEEK_API_KEY=your-key-here

# Lyrics search scrapes j-lyric.net and utaten.com — no API key needed.

# Optional — restrict which front-end origin may call the AI server. Defaults
# to '*'. Set this to your deployed PWA URL when front and server are on
# different hosts, e.g. CORS_ORIGIN=https://japp.example.com
CORS_ORIGIN=*

# Optional — single password that locks the app on a hosted deployment. When
# set, the app shows a password screen and the AI/keys endpoints reject requests
# without it (protects your keys/costs). Leave unset for an open local instance.
APP_PASSWORD=
